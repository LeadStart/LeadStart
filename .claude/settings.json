{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-git-write.sh",
            "if": "Bash(git *)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
