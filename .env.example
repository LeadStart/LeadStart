# Supabase (local dev values from `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Instantly.ai API
INSTANTLY_API_KEY=your-instantly-api-key

# Resend (for email reports)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=LeadStart <reports@yourdomain.com>

# Per-process Resend throttle (token bucket). Default 2 req/s — conservative
# against Resend's free-tier 2/s cap. Bump on paid plans (10/s standard).
RESEND_RATE_LIMIT_PER_SEC=2

# Webhook security
WEBHOOK_SECRET=your-random-secret-string

# HMAC secret for signed portal deep-links sent in hot-lead notification
# emails (4h TTL, single-use). Rotating this invalidates every outstanding
# link. Generate: openssl rand -hex 32
URL_SIGNING_SECRET=generate-with-openssl-rand-hex-32

# Stripe (billing)
# Test keys in dev (sk_test_…, pk_test_…), live in prod.
# STRIPE_WEBHOOK_SECRET is printed by `stripe listen --forward-to .../api/webhooks/stripe`
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# App URL used for Stripe Checkout success/cancel URLs and quote-page links.
# Include the /app basePath. Defaults to http://localhost:3000/app in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000/app
